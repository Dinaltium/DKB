{
  "name": "dkbus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-next-dir.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push --force",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "psql $DATABASE_URL -f drizzle/seed.sql",
    "db:seed-ts": "tsx --env-file=.env.local scripts/seed.ts",
    "db:setup": "pnpm db:push && pnpm db:seed-ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "15.4.11",
    "next-auth": "5.0.0-beta.30",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
